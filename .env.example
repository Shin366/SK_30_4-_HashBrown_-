# =====================================================================
# HashBrown 포렌식 대시보드 - 환경 변수 예시
# 사용 시 이 파일을 .env 로 복사 후 값 입력. (.env 는 git 에 커밋되지 않음)
# ⚠️ 실제 키는 절대 이 예시 파일에 넣지 말 것 — .env 에만 넣는다.
# =====================================================================

# (선택) 생성형 AI API 연동 키.
# 비워두면 대시보드는 100% 로컬 규칙기반 엔진으로 동작한다 (REQ-NF-005 기본값).
# 키를 넣으면 보고서/내러티브 생성 시 외부 AI API 를 호출할 수 있다.
VITE_AI_API_KEY=여기에_본인_키_입력_또는_앱에서_입력

# AI API 엔드포인트 (Anthropic Messages API). 비우면 로컬 폴백 사용.
VITE_AI_API_URL=https://api.anthropic.com/v1/messages

# 사용할 모델 ID (예: claude-fable-5 · claude-opus-4-8)
VITE_AI_MODEL=claude-fable-5
